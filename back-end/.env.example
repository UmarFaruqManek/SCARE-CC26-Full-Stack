# ============================================================
#  SCARE Backend — Environment Variables Template
#  Salin file ini menjadi ".env" lalu isi nilainya
# ============================================================

PORT=3000
NODE_ENV=development

# Kosongkan = pakai Mock (development)
# Isi dengan URL Flask Tim AI = pakai model asli (production)
# Contoh: MODEL_API_URL=https://scare-model.railway.app/predict
MODEL_API_URL=

# Isi saat deploy jika ingin riwayat prediksi tersimpan permanen di PostgreSQL hosted.
# Contoh Neon/Supabase:
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=
